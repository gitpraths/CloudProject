# GCP Project Configuration
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1

# Google Cloud Storage
BUCKET_NAME=your-gcs-bucket-name

# Vertex AI Model
MODEL_NAME=gemini-2.5-flash

# BigQuery (optional - not required for basic functionality)
BIGQUERY_DATASET=code_review
BIGQUERY_TABLE=reviews

# Google Cloud Credentials
# IMPORTANT: Set this as a Windows environment variable:
# setx GOOGLE_APPLICATION_CREDENTIALS "C:\path\to\your\service-account-key.json"
# Then restart your terminal
#
# Get your service account key from:
# GCP Console → IAM & Admin → Service Accounts → Create/Download JSON key

